### Obtener todos los productos
GET http://localhost:3000/products
Accept: application/json

###
GET http://localhost:3000/products/698f4ad2ba88a0d06e820e39
Accept: application/json

###
DELETE http://localhost:3000/products/69c6daa98e38cfca2a590a4e
Accept: application/json

### Crear un nuevo producto (Teclado Mecánico)
POST http://localhost:3000/products
Content-Type: application/json

{
  "title": "Teclado Mecánico RGB Pro V2",
  "description": "Un teclado mecánico de alto rendimiento con interruptores red, retroiluminación RGB personalizable y estructura de aluminio.",
  "short_description": "Teclado mecánico gamer con switches red.",
  "price": 129.99,
  "sale_price": 99.50,
  "sku": "KEY-RGB-PRO-V2",
  "stock_status": "in_stock",
  "stock_quantity": 45,
  "manage_stock": true,
  "type": "simple",
  "physical_attributes": {
    "length": 45.5,
    "width": 15.2,
    "height": 3.5,
    "weight": 1.2
  },
  "average_rating": 4.8,
  "custom_slug": null,
  "image": ""
}

